font_family      JetBrainsMono Nerd Font
font_size        13.0
symbol_map U+E0A0-U+E0B4 PowerlineSymbols

shell /bin/zsh
shell_integration enabled

map ctrl+v paste_from_clipboard

map ctrl+minus decrease_font_size
map ctrl+equal increase_font_size
map ctrl+plus increase_font_size

open_url_with xdg-open
mouse_map left click ungrabbed mouse_handle_click selection link prompt

# Random dark theme on every launch (see random-theme.sh).
# Runs the script at startup and inlines its output (a random theme's colors).
geninclude random-theme.sh
